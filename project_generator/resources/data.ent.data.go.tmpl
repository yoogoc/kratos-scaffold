package data

import (
	"context"
	"fmt"
	"log/slog"
	stdsql "database/sql"
	"{{.AppPkgPath}}/internal/biz"
	"{{.AppPkgPath}}/internal/conf"
	"{{.AppPkgPath}}/internal/data/ent"

	"entgo.io/ent/dialect/sql"
	"github.com/go-kratos/kratos/v3/log"
	"github.com/google/wire"

	_ "github.com/go-sql-driver/mysql"
	_ "github.com/jackc/pgx/v5/stdlib"
	"github.com/pkg/errors"
)

// ProviderSet is data providers.
var ProviderSet = wire.NewSet(NewEntClient, NewData, NewTxRepo, NewGreeterRepo)

type Data struct {
	log *slog.Logger
	db  *ent.Client
}

func (d *Data) WithEntTx(ctx context.Context, fn func(ctx context.Context) error) error {
	if tx := ent.TxFromContext(ctx); tx != nil {
		return fn(ctx)
	}
	tx, err := d.db.Tx(ctx)
	txContext := ent.NewTxContext(ctx, tx)
	if err != nil {
		return err
	}
	defer func() {
		if v := recover(); v != nil {
			_ = tx.Rollback()
			panic(v)
		}
	}()
	if err := fn(txContext); err != nil {
		if rerr := tx.Rollback(); rerr != nil {
			err = errors.Wrapf(err, "rolling back transaction: %v", rerr)
		}
		return err
	}
	if err := tx.Commit(); err != nil {
		return errors.Wrapf(err, "committing transaction: %v", err)
	}
	return nil
}

func (d *Data) EntClient(ctx context.Context) *ent.Client {
	tx := ent.TxFromContext(ctx)
	if tx != nil {
		return tx.Client()
	}
	return d.db
}

func NewTxRepo(d *Data) biz.TxRepo {
	return d
}

func NewEntClient(conf *conf.Data, logger *slog.Logger) *ent.Client {
	var ops []ent.Option
	if conf.Database.EntDebug {
		ops = append(ops, ent.Debug())
	}

	driverName := conf.Database.Driver
	switch conf.Database.Driver {
	case "postgres", "pg", "postgresql", "pgx":
		driverName = "pgx"
	}

	db, err := stdsql.Open(driverName, conf.Database.Source)
	if err != nil {
		panic(fmt.Sprintf("failed opening connection to db: %v", err))
	}

	return ent.NewClient(append(ops, ent.Driver(sql.NewDriver(conf.Database.Driver, sql.Conn{ExecQuerier: db})))...)
}

func NewData(conf *conf.Data, logger *slog.Logger, db *ent.Client) (*Data, error) {
	l := log.With(logger, "module", "{{.LoggerName}}")
	return &Data{
		log: l,
		db:  db,
	}, nil
}

func applyListOptions(opts *biz.ListOptions) func(*sql.Selector) {
	return func(s *sql.Selector) {
		if opts.PageSize > 0 {
			s.Limit(opts.PageSize)
			s.Offset((opts.Page - 1) * opts.PageSize)
		}
		for _, ob := range opts.OrderBy {
			if ob.Desc {
				s.OrderBy(sql.Desc(ob.Field))
			} else {
				s.OrderBy(sql.Asc(ob.Field))
			}
		}
	}
}
