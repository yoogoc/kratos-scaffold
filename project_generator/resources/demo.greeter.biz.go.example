package biz

import (
	"context"

	"github.com/go-kratos/kratos/v2/log"
)

type GreeterRepo interface {
	SayHello(ctx context.Context, name string) (string, error)
}

type GreeterUsecase struct {
	repo GreeterRepo
	log  *log.Helper
}

func NewGreeterUsecase(repo GreeterRepo, logger log.Logger) *GreeterUsecase {
	return &GreeterUsecase{
		repo: repo,
		log:  log.NewHelper(log.With(logger, "module", "biz/greeter")),
	}
}

func (uc *GreeterUsecase) SayHello(ctx context.Context, name string) (string, error) {
	uc.log.WithContext(ctx).Infof("SayHello: %s", name)
	return uc.repo.SayHello(ctx, name)
}
